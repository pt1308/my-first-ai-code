   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 生成1000个随机数\n",
    "data = np.random.randn(1000)\n",
    "\n",
    "# 画直方图\n",
    "plt.hist(data, bins=30, edgecolor='black')\n",
    "plt.title(\"随机数的分布\")\n",
    "plt.xlabel(\"数值\")\n",
    "plt.ylabel(\"频数\")\n",
    "plt.show()\n",
    "\n",
    "print(\"随机数的平均值是:\", np.mean(data))\n",
    "print(\"随机数的标准差是:\", np.std(data))"
   ]
  },
